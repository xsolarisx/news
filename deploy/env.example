# /etc/news-digest/env — environment variables for news-digest.service
#
# Copy this file to /etc/news-digest/env on the LXC container and fill in
# the values for the API keys you intend to use.  Keys left blank will
# simply not be exported to the process; the script will raise an error at
# runtime if it needs a key that was not provided.
#
# Permissions: this file should be owned root:newsdigest with mode 640 so
# that the service user can read it but other unprivileged users cannot.
#   chown root:newsdigest /etc/news-digest/env
#   chmod 640 /etc/news-digest/env
#
# Lines beginning with '#' are comments and are ignored by systemd.
# Do NOT quote values — systemd reads them literally (no shell expansion).

# ---------------------------------------------------------------------------
# LLM / AI provider keys
# ---------------------------------------------------------------------------

# OpenAI API key — used if the digest tool calls the OpenAI API.
# Obtain from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic API key — used if the digest tool calls the Anthropic / Claude API.
# Obtain from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Optional overrides
# ---------------------------------------------------------------------------

# Override the default output path (must be writable by the newsdigest user).
# Uncomment and set if you want the HTML written somewhere other than the default.
# OUTPUT_FILE=/opt/news-digest/output/digest.html

# Log level for the Python script (DEBUG, INFO, WARNING, ERROR).
# Default is INFO.
# LOG_LEVEL=INFO
